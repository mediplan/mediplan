    },
    "spirometry_result": {
      "type": "string"
    },
    "spirometry_result_done": {
      "type": "boolean",
      "default": false
    },
    "spirometry_result_date": {
      "type": "string",
      "format": "date"
    },
    "ecg_result": {
      "type": "string"
    },
    "ecg_result_done": {
      "type": "boolean",
      "default": false
    },
    "ecg_result_date": {
      "type": "string",
      "format": "date"
    },
    "blood_tests_result": {
      "type": "string"
    },
    "blood_tests_result_done": {
      "type": "boolean",
      "default": false
    },
    "blood_tests_result_date": {
      "type": "string",
      "format": "date"
    },
    "urine_test_result": {
      "type": "string"
    },
    "urine_test_result_done": {
      "type": "boolean",
      "default": false
    },
    "urine_test_result_date": {
      "type": "string",
      "format": "date"
    },
    "drug_test_result": {
      "type": "string"
    },
    "drug_test_result_done": {
      "type": "boolean",
      "default": false
    },
    "drug_test_result_date": {
      "type": "string",
      "format": "date"
    },
    "other_exams": {
      "type": "string"
    },
    "other_exams_done": {
      "type": "boolean",
      "default": false
    },
    "other_exams_date": {
      "type": "string",
      "format": "date"
    },
    "diagnosis": {
      "type": "string"
    },
    "judgment": {
      "type": "string",
