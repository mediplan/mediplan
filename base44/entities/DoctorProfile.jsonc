{
  "name": "DoctorProfile",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "ID tenant di appartenenza"
    },
    "full_name": {
      "type": "string",
      "description": "Nome completo del medico"
    },
    "specialization": {
      "type": "string",
      "description": "Specializzazione (es. Medicina del Lavoro)"
    },
    "birth_place": {
      "type": "string",
      "description": "Luogo di nascita"
    },
    "birth_date": {
      "type": "string",
      "format": "date",
      "description": "Data di nascita"
    },
    "fiscal_code": {
      "type": "string",
      "description": "Codice fiscale del medico"
    },
    "user_id": {
      "type": "string",
      "description": "ID utente associato (se ha accesso al sistema)"
    },
    "user_email": {
      "type": "string",
      "description": "Email utente associato"
    },
    "phone": {
      "type": "string",
      "description": "Telefono"
    },
    "notes": {
      "type": "string",
      "description": "Note"
    },
    "signature_url": {
      "type": "string",
      "description": "URL immagine firma del medico"
    },
    "active": {
      "type": "boolean",
      "description": "Medico attivo",
      "default": true
    }
  },
  "required": [
    "full_name"
  ]
}